# Core (required)
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VAULT_PATH=/data/vault
GIT_REMOTE_URL=git@github.com:user/vault.git
TZ=America/Sao_Paulo

# Phase 2 — Google Calendar + Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

# Phase 2 — Knowledge ingestion
TRANSCRIPT_DIR=/data/transcripts
OPENAI_API_KEY=

# Phase 3 — ShipLens
SHIPLENS_TRANSPORT=http
SHIPLENS_URL=http://localhost:4000
SHIPLENS_COMMAND=

# Phase 3 — Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_SQUAD_MAPPING={"SF-PLATFORM":"Platform","SF-GROWTH":"Growth","SF-CORE":"Core"}

# Phase 3 — GitHub
GITHUB_TOKEN=
GITHUB_ORG=your-org
GITHUB_REPOS=repo1,repo2,repo3

# Phase 4 — ChromaDB
CHROMA_URL=http://localhost:8000

# Phase 5 — Platform API
API_TOKEN=          # Bearer token for web UI auth (leave empty for open access in dev)
ENCRYPTION_KEY=     # 32-byte hex key for OAuth token encryption (auto-generated if empty)
PORT=3000           # API + frontend server port
