# DevContainer — development environment for Tela coding agents
# Build: docker build -f Dockerfile.devcontainer -t tela-devcontainer:latest .

FROM node:22-slim

# Install dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    ripgrep \
    tree \
    jq \
    make \
    openssh-client \
    python3 \
    python3-pip \
    python3-venv \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm, Claude Code CLI, and InsForge MCP globally
RUN npm install -g pnpm @anthropic-ai/claude-code @insforge/mcp

# Use the existing 'node' user (UID 1000) from the base image
# Claude Code refuses --dangerously-skip-permissions as root
RUN mkdir -p /workspace && chown node:node /workspace

USER node
WORKDIR /workspace

ENV NODE_ENV=development
ENV HOME=/home/node

# Pre-expose common dev ports
EXPOSE 3000 3001 4000 5173 8000 8080

CMD ["bash"]
